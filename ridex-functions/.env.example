# Copy this file to setup/.env before running schema.js locally.
# Appwrite CLI deployments now use ridex-functions/appwrite.config.json.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_server_api_key_here
APPWRITE_DB_ID=your_db_value
APPWRITE_TABLE_USERS=your_table_users_value
APPWRITE_TABLE_DRIVER_PROFILES=your_driver_profiles_collection_id
APPWRITE_TABLE_RIDES=your_rides_collection_id
APPWRITE_TABLE_RIDE_OFFERS=your_ride_offers_collection_id
APPWRITE_TABLE_PAYMENTS=your_payments_collection_id
APPWRITE_TABLE_PAYMENT_METHODS=your_payment_methods_collection_id
APPWRITE_TABLE_EMERGENCY_CONTACTS=your_emergency_contacts_collection_id
APPWRITE_TABLE_RATINGS=your_ratings_collection_id
APPWRITE_TABLE_PROMO_CODES=your_promo_codes_collection_id
APPWRITE_TABLE_SUPPORT_TICKETS=your_support_tickets_collection_id
APPWRITE_FUNCTION_MATCH_DRIVER=your_match_driver_function_id
APPWRITE_FUNCTION_DRIVER_TOGGLE=your_driver_toggle_function_id
APPWRITE_FUNCTION_ACCEPT_RIDE=your_accept_ride_function_id
APPWRITE_FUNCTION_CREATE_CASH_BOOKING=your_create_cash_booking_function_id
APPWRITE_FUNCTION_CREATE_STRIPE_CHECKOUT=your_create_stripe_checkout_function_id
APPWRITE_FUNCTION_COMPLETE_STRIPE_BOOKING=your_complete_stripe_booking_function_id
APPWRITE_FUNCTION_START_TRIP=your_start_trip_function_id
APPWRITE_FUNCTION_END_TRIP=your_end_trip_function_id
APPWRITE_FUNCTION_RAISE_SUPPORT_TICKET=your_raise_support_ticket_function_id
APPWRITE_FUNCTION_ADMIN_UPDATE_TICKET=your_admin_update_ticket_function_id
APPWRITE_FUNCTION_ADMIN_UPDATE_PAYMENT=your_admin_update_payment_function_id
APPWRITE_FUNCTION_SUBMIT_RATING=your_submit_rating_function_id
APPWRITE_FUNCTION_APPLY_PROMO=your_apply_promo_function_id
APPWRITE_FUNCTION_SEND_SOS=your_send_sos_function_id
APP_BASE_URL=http://localhost:5173
SOS_WEBHOOK_URL=your_sos_webhook_url_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_CURRENCY=inr
